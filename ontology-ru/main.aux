\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Язык --- серийная разгрузка объёмного аккорда через одномерное ушко. Теснота канала --- теорема, не метафора: отсюда и длина «полной мысли», и сама нужда в грамматике.}}{16}{figure.caption.15}\protected@file@percent }
