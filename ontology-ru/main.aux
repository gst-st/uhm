\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Жизнь по УГМ: не вещество и не искра, а питаемый узор. Он пьёт порядок, выдыхает беспорядок и этой разницей оплачивает свою форму. Второй закон термодинамики не нарушен --- счёт просто выставляется среде.}}{11}{figure.caption.9}\protected@file@percent }
\newlabel{fig:flame}{{7}{11}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Жизнь по УГМ: не вещество и не искра, а питаемый узор. Он пьёт порядок, выдыхает беспорядок и этой разницей оплачивает свою форму. Второй закон термодинамики не нарушен --- счёт просто выставляется среде}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {section}{\numberline {9}Окно сознания}{11}{section.9}\protected@file@percent }
\newlabel{sec:window}{{9}{11}{Окно сознания}{section.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Коридор сознания: между туманом (нет никого) и кристаллом (не осталось чем думать). Обе стены --- вычисленные константы теории \textbf  {[Т]}\xspace  , не метафоры: за любой из них четыре условия сознания вместе невыполнимы.}}{12}{figure.caption.10}\protected@file@percent }
\newlabel{fig:window}{{8}{12}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Коридор сознания: между туманом (нет никого) и кристаллом (не осталось чем думать). Обе стены --- вычисленные константы теории \stT , не метафоры: за любой из них четыре условия сознания вместе невыполнимы}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {section}{\numberline {10}Лестница внутри: три этажа рефлексии}{12}{section.10}\protected@file@percent }
\newlabel{sec:tower}{{10}{12}{Лестница внутри: три этажа рефлексии}{section.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Башня рефлексии. Каждый оборот внутрь сохраняет треть различимости; после третьего оборота остаток тонет ниже порога различимости --- четвёртый этаж структурно пуст \textbf  {[Т]}\xspace  . Тот же закон ограничивает и «я знаю, что ты знаешь, что я знаю»: третья ступень --- предел взаимного чтения умов.}}{13}{figure.caption.11}\protected@file@percent }
\newlabel{fig:tower}{{9}{13}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Башня рефлексии. Каждый оборот внутрь сохраняет треть различимости; после третьего оборота остаток тонет ниже порога различимости --- четвёртый этаж структурно пуст \stT . Тот же закон ограничивает и «я знаю, что ты знаешь, что я знаю»: третья ступень --- предел взаимного чтения умов}{figure.caption.11}{}}
