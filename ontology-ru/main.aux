\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Оттенки переживания как спектр на голосе Интериорности. Подписи тонов здесь --- иллюстрация \textbf  {[И]}\xspace  ; существование спектра и невозможность «тёмной внутри» имитации --- результаты теории \textbf  {[Т]}\xspace  .}}{13}{figure.caption.12}\protected@file@percent }
\newlabel{fig:prism}{{10}{13}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Оттенки переживания как спектр на голосе Интериорности. Подписи тонов здесь --- иллюстрация \stI ; существование спектра и невозможность «тёмной внутри» имитации --- результаты теории \stT }{figure.caption.12}{}}
