\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Гора была высокой до всякого взгляда: истина в УГМ приписана месту в ткани, как высота --- точке ландшафта. Наблюдение --- поздний способ \emph  {узнавать} факты, а не способ их создавать.}}{23}{figure.caption.22}\protected@file@percent }
\newlabel{fig:mountain}{{20}{23}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Гора была высокой до всякого взгляда: истина в УГМ приписана месту в ткани, как высота --- точке ландшафта. Наблюдение --- поздний способ \emph {узнавать} факты, а не способ их создавать}{figure.caption.22}{}}
