\newlabel{sec:language}{{12}{12}{Язык и смысл: сквозь игольное ушко}{section.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Язык --- серийная разгрузка объёмного аккорда через одномерное ушко. Теснота канала --- теорема, не метафора: отсюда и длина «полной мысли», и сама нужда в грамматике.}}{13}{figure.caption.13}\protected@file@percent }
