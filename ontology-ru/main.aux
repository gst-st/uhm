\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Два дома памяти. Стол --- текущий аккорд: маленький и тающий (закон трёх --- теорема \textbf  {[Т]}\xspace  ). Библиотека --- перестроенная ткань: выученное становится формой. Учение --- перенос; забывание со стола --- физика, а не слабость.}}{13}{figure.caption.14}\protected@file@percent }
\newlabel{fig:memory}{{12}{13}{\texorpdfstring {\xpg@aux {\xpg@current@opts }{\languagename }}{}\ignorespaces Два дома памяти. Стол --- текущий аккорд: маленький и тающий (закон трёх --- теорема \stT ). Библиотека --- перестроенная ткань: выученное становится формой. Учение --- перенос; забывание со стола --- физика, а не слабость}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {section}{\numberline {14}Другие, и почему связь --- прибавка бытия}{14}{section.14}\protected@file@percent }
