\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces \xpg@aux {}{russian}\ignorespaces Гадательное колесо под микроскопом: честные часы, скрытая двоичная комбинаторика, подпись Кеплера в кривой года --- и поверх всего рассказчик, чей мост к судьбе человека не поддержан ничем. Разобрать --- уважительнее, чем верить или смеяться.}}{24}{figure.caption.23}\protected@file@percent }
